#!/usr/bin/env bash
# riscv64-clang — Wrapper for locally-built LLVM clang (C compiler).
#
# Usage:
#   ./tools/local-llvm/riscv64-clang [OPTIONS] <source>
#
# Options:
#   --march=<ARCH>  Select RISC-V march (default: rv64gcv)
#                   Common values: rv64gc, rv64gcv, rv64imafc
#   --version       Show clang version
#   --help          Show clang help

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" &>/dev/null && pwd)"
source "$SCRIPT_DIR/common.sh"

CLANG=$(resolve_tool clang)

# Parse custom options
TARGET_ARGS=("--target=riscv64-unknown-linux-gnu")
EXTRA_ARGS=()
MARCH="rv64gcv"

for arg in "$@"; do
    case "$arg" in
        --march=*)
            MARCH="${arg#*=}"
            ;;
        --version|--help)
            exec "$CLANG" "${TARGET_ARGS[@]}" "$@"
            ;;
        *)
            EXTRA_ARGS+=("$arg")
            ;;
    esac
done

exec "$CLANG" "${TARGET_ARGS[@]}" "-march=${MARCH}" "${EXTRA_ARGS[@]}"
