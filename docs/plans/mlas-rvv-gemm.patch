diff --git a/onnxruntime/core/mlas/lib/riscv64/SgemmKernelRvv.cpp b/onnxruntime/core/mlas/lib/riscv64/SgemmKernelRvv.cpp
new file mode 100644
index 0000000..f62680e
--- /dev/null
+++ b/onnxruntime/core/mlas/lib/riscv64/SgemmKernelRvv.cpp
@@ -0,0 +1,262 @@
+/*++
+
+Copyright (c) RVFuse Project. All rights reserved.
+
+Licensed under the MIT License.
+
+Module Name:
+
+    SgemmKernelRvv.cpp
+
+Abstract:
+
+    This module implements the RVV (RISC-V Vector Extension) kernel for the
+    single precision matrix/matrix multiply operation (SGEMM).
+
+    This is a BB-level vectorization of the scalar SgemmKernel: the inner K
+    loop replaces 4 scalar fmadd.s with 1 vfmacc.vf (VL=4), matching the
+    existing B packing width of 4 columns.
+
+--*/
+
+#include "mlasi.h"
+
+#if defined(__riscv_v)
+
+#include <riscv_vector.h>
+
+//
+// Inner kernel: computes a 4x1 or 4x2 output block using RVV intrinsics.
+// VL=4 processes 4 packed B columns per vector instruction.
+//
+
+template<bool ZeroMode, bool ProcessTwoRows>
+size_t
+MlasSgemmKernelRvv(
+    const float* A,
+    const float* B,
+    float* C,
+    size_t CountK,
+    size_t CountN,
+    size_t lda,
+    size_t ldc,
+    float alpha
+    )
+{
+    constexpr size_t kVlen = 4; // Match MLAS B packing width
+    const size_t vl = __riscv_vsetvl_e32m1(kVlen);
+
+    int countb = 0;
+
+    do {
+        //
+        // Clear the vector accumulators.
+        //
+        vfloat32m1_t v_acc_r0 = __riscv_vfmv_v_f_f32m1(0.0f, vl);
+        vfloat32m1_t v_acc_r1 = __riscv_vfmv_v_f_f32m1(0.0f, vl);
+
+        const float* a = A;
+        const float* b = B;
+        size_t k = CountK;
+
+        //
+        // Vectorized K loop, unrolled by 2 (matching scalar kernel).
+        //
+        // Per iteration:
+        //   Scalar kernel: 8 flw + 16 fmadd.s = 24 compute instructions
+        //   RVV kernel:    4 flw + 2 vle32.v + 4 vfmacc.vf = 10 instructions
+        //
+
+        while (k >= 2) {
+
+            //
+            // Load A elements (scalar — broadcast into vector FMA).
+            //
+            float a0_r0 = a[0];
+            float a1_r0 = a[1];
+
+            float a0_r1 = 0.0f;
+            float a1_r1 = 0.0f;
+            if (ProcessTwoRows) {
+                a0_r1 = a[lda];
+                a1_r1 = a[lda + 1];
+            }
+
+            //
+            // Load B[0..3] (K element 0) and FMA.
+            //
+            vfloat32m1_t v_b0 = __riscv_vle32_v_f32m1(b, vl);
+            v_acc_r0 = __riscv_vfmacc_vf_f32m1(v_acc_r0, a0_r0, v_b0, vl);
+            if (ProcessTwoRows) {
+                v_acc_r1 = __riscv_vfmacc_vf_f32m1(v_acc_r1, a0_r1, v_b0, vl);
+            }
+
+            //
+            // Load B[16..19] (K element 1) and FMA.
+            // Offset 16 floats = 64 bytes (same packing layout as scalar kernel).
+            //
+            vfloat32m1_t v_b1 = __riscv_vle32_v_f32m1(b + 16, vl);
+            v_acc_r0 = __riscv_vfmacc_vf_f32m1(v_acc_r0, a1_r0, v_b1, vl);
+            if (ProcessTwoRows) {
+                v_acc_r1 = __riscv_vfmacc_vf_f32m1(v_acc_r1, a1_r1, v_b1, vl);
+            }
+
+            a += 2;
+            b += 32;    // B packing stride: 32 floats per K-pair
+            k -= 2;
+        }
+
+        //
+        // Handle remaining K element (odd CountK).
+        //
+        if (k > 0) {
+            float a0_r0 = a[0];
+            float a0_r1 = 0.0f;
+            if (ProcessTwoRows) {
+                a0_r1 = a[lda];
+            }
+
+            vfloat32m1_t v_b0 = __riscv_vle32_v_f32m1(b, vl);
+            v_acc_r0 = __riscv_vfmacc_vf_f32m1(v_acc_r0, a0_r0, v_b0, vl);
+            if (ProcessTwoRows) {
+                v_acc_r1 = __riscv_vfmacc_vf_f32m1(v_acc_r1, a0_r1, v_b0, vl);
+            }
+        }
+
+        //
+        // Multiply accumulators by alpha.
+        //
+        v_acc_r0 = __riscv_vfmul_vf_f32m1(v_acc_r0, alpha, vl);
+        if (ProcessTwoRows) {
+            v_acc_r1 = __riscv_vfmul_vf_f32m1(v_acc_r1, alpha, vl);
+        }
+
+        if (CountN >= 4) {
+
+            //
+            // Store the full 4-element output block.
+            //
+            if (!ZeroMode) {
+                vfloat32m1_t v_c = __riscv_vle32_v_f32m1(C, vl);
+                v_acc_r0 = __riscv_vfadd_vv_f32m1(v_acc_r0, v_c, vl);
+            }
+            __riscv_vse32_v_f32m1(C, v_acc_r0, vl);
+
+            if (ProcessTwoRows) {
+                if (!ZeroMode) {
+                    vfloat32m1_t v_c = __riscv_vle32_v_f32m1(C + ldc, vl);
+                    v_acc_r1 = __riscv_vfadd_vv_f32m1(v_acc_r1, v_c, vl);
+                }
+                __riscv_vse32_v_f32m1(C + ldc, v_acc_r1, vl);
+            }
+
+        } else {
+
+            //
+            // Store the partial output block (CountN < 4).
+            // Extract scalars from vector for masked store.
+            //
+            float row0[4], row1[4];
+            __riscv_vse32_v_f32m1(row0, v_acc_r0, vl);
+            if (ProcessTwoRows) {
+                __riscv_vse32_v_f32m1(row1, v_acc_r1, vl);
+            }
+
+            if ((CountN & 2) != 0) {
+
+                if (!ZeroMode) {
+                    row0[0] = row0[0] + C[0];
+                    row0[1] = row0[1] + C[1];
+                }
+
+                C[0] = row0[0];
+                C[1] = row0[1];
+                row0[0] = row0[2];
+                row0[1] = row0[3];
+
+                if (ProcessTwoRows) {
+
+                    if (!ZeroMode) {
+                        row1[0] = row1[0] + C[ldc];
+                        row1[1] = row1[1] + C[ldc + 1];
+                    }
+
+                    C[ldc] = row1[0];
+                    C[ldc + 1] = row1[1];
+                    row1[0] = row1[2];
+                    row1[1] = row1[3];
+                }
+
+                C += 2;
+            }
+
+            if ((CountN & 1) != 0) {
+
+                if (!ZeroMode) {
+                    row0[0] = row0[0] + C[0];
+                }
+
+                C[0] = row0[0];
+
+                if (ProcessTwoRows) {
+
+                    if (!ZeroMode) {
+                        row1[0] = row1[0] + C[ldc];
+                    }
+
+                    C[ldc] = row1[0];
+                }
+            }
+
+            break;
+        }
+
+        B += 4;
+        C += 4;
+        CountN -= 4;
+
+        countb = (countb + 1) % 4;
+        if (countb == 0) {
+            B += CountK * 16 - 16;
+        }
+
+    } while (CountN > 0);
+
+    return ProcessTwoRows ? 2 : 1;
+}
+
+//
+// Dispatch entry point matching MLAS_GEMM_FLOAT_KERNEL signature.
+//
+
+size_t
+MLASCALL
+MlasSgemmKernelRvv(
+    const float* A,
+    const float* B,
+    float* C,
+    size_t CountK,
+    size_t CountM,
+    size_t CountN,
+    size_t lda,
+    size_t ldc,
+    float alpha,
+    bool ZeroMode
+    )
+{
+    if (ZeroMode) {
+        if (CountM >= 2) {
+            return MlasSgemmKernelRvv<true, true>(A, B, C, CountK, CountN, lda, ldc, alpha);
+        } else {
+            return MlasSgemmKernelRvv<true, false>(A, B, C, CountK, CountN, lda, ldc, alpha);
+        }
+    } else {
+        if (CountM >= 2) {
+            return MlasSgemmKernelRvv<false, true>(A, B, C, CountK, CountN, lda, ldc, alpha);
+        } else {
+            return MlasSgemmKernelRvv<false, false>(A, B, C, CountK, CountN, lda, ldc, alpha);
+        }
+    }
+}
+
+#endif // __riscv_v
