+++ b/onnxruntime/core/mlas/lib/riscv64/SgemmKernelRvv512.cpp
@@ -0,0 +1,68 @@
+/*++
+
+Copyright (c) RVFuse Project. All rights reserved.
+
+Licensed under the MIT License.
+
+Module Name:
+
+    SgemmKernelRvv512.cpp
+
+Abstract:
+
+    This module implements the RVV (RISC-V Vector Extension) kernel for the
+    single precision matrix/matrix multiply operation (SGEMM) targeting
+    512-bit vector registers (VLEN=512, SEW=32, LMUL=1, VL=16).
+
+    The implementation is in rvv_sgemm_kernel_vl16.inl (single source of truth),
+    shared with the standalone correctness test.
+
+--*/
+
+#include "mlasi.h"
+
+#if defined(__riscv_v)
+
+// Include template implementation with C++ linkage (templates require it)
+#define RVV_SGEMM_KERNEL_VL16_IMPL
+#include "rvv_sgemm_kernel_vl16.inl"
+#undef RVV_SGEMM_KERNEL_VL16_IMPL
+
+// Dispatch entry point — must have C linkage to match mlasi.h declaration.
+// mlasi.h line 974 declares: MLAS_GEMM_FLOAT_KERNEL MlasSgemmKernelRvv512;
+// inside an extern "C" block, so the definition here must also use extern "C".
+extern "C" {
+
+size_t
+MLASCALL
+MlasSgemmKernelRvv512(
+    const float* A,
+    const float* B,
+    float* C,
+    size_t CountK,
+    size_t CountM,
+    size_t CountN,
+    size_t lda,
+    size_t ldc,
+    float alpha,
+    bool ZeroMode
+    )
+{
+    if (ZeroMode) {
+        if (CountM >= 2) {
+            return MlasSgemmKernelRvv512Impl<true, true>(A, B, C, CountK, CountN, lda, ldc, alpha);
+        } else {
+            return MlasSgemmKernelRvv512Impl<true, false>(A, B, C, CountK, CountN, lda, ldc, alpha);
+        }
+    } else {
+        if (CountM >= 2) {
+            return MlasSgemmKernelRvv512Impl<false, true>(A, B, C, CountK, CountN, lda, ldc, alpha);
+        } else {
+            return MlasSgemmKernelRvv512Impl<false, false>(A, B, C, CountK, CountN, lda, ldc, alpha);
+        }
+    }
+}
+
+} // extern "C"
+
+#endif // __riscv_v

