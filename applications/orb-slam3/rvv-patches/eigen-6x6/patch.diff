--- /dev/null
+++ b/Eigen/src/Core/arch/RVV/PacketMath.h
@@ -0,0 +1,43 @@
+// RVV PacketMath for Eigen 3.4.0
+// Provides RVV vectorization infrastructure.
+// NOTE: size=1 (safe mode) to avoid breaking non-6x6 operations.
+// The specialized 6x6 kernels are in eigen_rvv.inl for explicit use.
+
+#ifndef EIGEN_PACKET_MATH_RVV_H
+#define EIGEN_PACKET_MATH_RVV_H
+
+#include <riscv_vector.h>
+
+namespace Eigen {
+namespace internal {
+
+template<> struct packet_traits<double> : default_packet_traits {
+    typedef double type;
+    typedef double half;
+    enum {
+        Vectorizable = 0,
+        size = 1,
+        HasAdd = 0, HasSub = 0, HasMul = 0, HasDiv = 0,
+        HasFma = 0, HasNegate = 0, HasAbs = 0,
+        HasBlend = 0,
+        AlignedOnScalar = 1
+    };
+};
+
+} // namespace internal
+} // namespace Eigen
+
+#endif // EIGEN_PACKET_MATH_RVV_H

