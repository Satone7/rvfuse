+// Q5_0 interleaved block for 8-column GEMV
+// Custom structure (not from template<> since Q5_0 has 5-bit packing + qh bitmask)
+struct block_q5_0x8 {
+    ggml_half d[8];       // 8 half-precision scale factors (16 bytes)
+    uint8_t qh[8][4];     // 8 x 4-byte qh bitmasks (32 bytes)
+    uint8_t qs[128];      // interleaved nibble-packed quants (128 bytes)
+                          // Layout: [col0_b0|col1_b0|...|col7_b0|col0_b1|...|col7_b3]
+};
+static_assert(sizeof(block_q5_0x8) == 176, "wrong q5_0x8 block size/padding");
