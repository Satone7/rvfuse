+// ---------------------------------------------------------------------------
+// ggml_gemv_q5_0_q8_0_generic: scalar reference for Q5_0 x Q8_0 GEMV (8x8)
+// ---------------------------------------------------------------------------
+// This follows the same pattern as ggml_gemv_q4_0_8x8_q8_0_generic but
+// with 5-bit dequantization (nibble + qh bitmask) instead of 4-bit.
+void ggml_gemv_q5_0_q8_0_generic(int n, float * GGML_RESTRICT s, size_t bs,
+    const void * GGML_RESTRICT vx, const void * GGML_RESTRICT vy,
+    int nr, int nc) {
+    const int qk = QK8_0;  // 32
+    const int nb = n / qk;
+    const int ncols_interleaved = 8;
+    const int blocklen = 8;
+
+    assert(n % qk == 0);
+    assert(nc % ncols_interleaved == 0);
+
+    GGML_UNUSED(bs);
+    GGML_UNUSED(nr);
+
+    float sumf[8];
+    int sumi;
+
+    const block_q8_0 * a_ptr = (const block_q8_0 *) vy;
+    for (int x = 0; x < nc / ncols_interleaved; x++) {
+        const block_q5_0x8 * b_ptr = (const block_q5_0x8 *) vx + (x * nb);
+
+        for (int j = 0; j < ncols_interleaved; j++) sumf[j] = 0.0;
+        for (int l = 0; l < nb; l++) {
+            for (int k = 0; k < (qk / (2 * blocklen)); k++) {
+                for (int j = 0; j < ncols_interleaved; j++) {
+                    sumi = 0;
+                    for (int i = 0; i < blocklen; ++i) {
+                        const int qs_idx = k * ncols_interleaved * blocklen + j * blocklen + i;
+                        const int elem_lo = k * blocklen + i;
+                        const int xh_0 = (b_ptr[l].qh[j][elem_lo / 8] >> (elem_lo % 8)) & 1;
+                        const int v0 = (int8_t)(((b_ptr[l].qs[qs_idx] & 0x0F) | (xh_0 << 4)) - 16);
+                        const int elem_hi = k * blocklen + i + qk / 2;
+                        const int xh_1 = (b_ptr[l].qh[j][elem_hi / 8] >> (elem_hi % 8)) & 1;
+                        const int v1 = (int8_t)(((b_ptr[l].qs[qs_idx] >> 4) | (xh_1 << 4)) - 16);
+                        sumi += v0 * a_ptr[l].qs[k * blocklen + i]
+                              + v1 * a_ptr[l].qs[k * blocklen + i + qk / 2];
+                    }
+                    sumf[j] += sumi * GGML_CPU_FP16_TO_FP32(b_ptr[l].d[j])
+                                    * GGML_CPU_FP16_TO_FP32(a_ptr[l].d);
+                }
+            }
+        }
+        for (int j = 0; j < ncols_interleaved; j++) s[x * ncols_interleaved + j] = sumf[j];
+    }
+}
