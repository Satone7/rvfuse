diff --git a/onnxruntime/core/mlas/lib/riscv64/SoftmaxKernelRvvFp16.cpp b/onnxruntime/core/mlas/lib/riscv64/SoftmaxKernelRvvFp16.cpp
new file mode 100644
index 0000000..a1b2c3d
--- /dev/null
+++ b/onnxruntime/core/mlas/lib/riscv64/SoftmaxKernelRvvFp16.cpp
@@ -0,0 +1,108 @@
+/*++
+
+Copyright (c) RVFuse Project. All rights reserved.
+
+Licensed under the MIT License.
+
+Module Name:
+
+    SoftmaxKernelRvvFp16.cpp
+
+Abstract:
+
+    RVV FP16 softmax kernel registration for MLAS dispatch.
+
+    This file includes the RVV softmax implementation (softmax_fp16_rvv512.inl)
+    and creates the MLAS_SOFTMAX_DISPATCH function pointer table that
+    MLAS uses to dispatch FP16 softmax operations.
+
+    Target: VLEN=512, SEW=16 (FP16), LMUL=1, VL=32 elements.
+    Requires: __riscv_zvfh (half-precision floating-point vector extension)
+
+--*/
+
+#include "mlasi.h"
+#include "softmax.h"
+
+#if defined(MLAS_TARGET_RISCV) && defined(MLAS_RVV_VLEN_512) && defined(__riscv_zvfh)
+
+#include <riscv_vector.h>
+
+// Include the core RVV FP16 softmax implementation
+// This contains: ExpVectorFp16, SumExpVectorFp16, ReduceMax_Kernel_Fp16_Rvv512,
+//                SumExp_Kernel_Fp16_Rvv512, Softmax_Kernel_Fp16_Rvv512,
+//                Exp_Kernel_Fp16_Rvv512, LogSoftmax_Kernel_Fp16_Rvv512
+#include "softmax_fp16_rvv512.inl"
+
+//
+// MLAS dispatch wrapper functions.
+// These functions match the MLAS_SOFTMAX_DISPATCH function pointer signatures.
+//
+
+namespace {
+
+MLAS_FP16
+ReduceMaxWrapper(const MLAS_FP16* Input, size_t N) {
+    return softmax_rvv512::ReduceMax_Kernel_Fp16_Rvv512(Input, N);
+}
+
+MLAS_FP16
+SumExpWrapper(const MLAS_FP16* Input, MLAS_FP16* Output, size_t N,
+              const MLAS_FP16 NegativeMaximum) {
+    return softmax_rvv512::SumExp_Kernel_Fp16_Rvv512(Input, Output, N,
+                                                         NegativeMaximum);
+}
+
+void
+SoftmaxWrapper(const MLAS_FP16* Input, MLAS_FP16* Output, size_t N,
+               const MLAS_FP16 Sum) {
+    softmax_rvv512::Softmax_Kernel_Fp16_Rvv512(Input, Output, N, Sum);
+}
+
+void
+LogSoftmaxWrapper(const MLAS_FP16* Input, MLAS_FP16* Output, size_t N,
+                  const MLAS_FP16 NegativeMaximum, const MLAS_FP16 LogSum) {
+    softmax_rvv512::LogSoftmax_Kernel_Fp16_Rvv512(Input, Output, N,
+                                                     NegativeMaximum, LogSum);
+}
+
+void
+ExpWrapper(const MLAS_FP16* Input, MLAS_FP16* Output, size_t N) {
+    softmax_rvv512::Exp_Kernel_Fp16_Rvv512(Input, Output, N);
+}
+
+//
+// Static dispatch table for RVV FP16 softmax kernels.
+// Tanh_Fp16 and Softcap_Fp16 are not yet implemented.
+//
+
+MLAS_SOFTMAX_DISPATCH SoftmaxDispatchRvvFp16Storage = {
+    /*Tanh_Fp16*/       nullptr,           // TODO: implement Tanh_Fp16
+    /*Softcap_Fp16*/    nullptr,           // TODO: implement Softcap_Fp16
+    /*Exp_Fp16*/        ExpWrapper,
+    /*ReduceMax_Fp16*/  ReduceMaxWrapper,
+    /*SumExp_Fp16*/     SumExpWrapper,
+    /*Softmax_Fp16*/    SoftmaxWrapper,
+    /*LogSoftmax_Fp16*/ LogSoftmaxWrapper,
+};
+
+}  // anonymous namespace
+
+//
+// Global dispatch pointer accessible from platform.cpp.
+//
+
+MLAS_SOFTMAX_DISPATCH* SoftmaxDispatchRvvFp16 = &SoftmaxDispatchRvvFp16Storage;
+
+#endif // MLAS_TARGET_RISCV && MLAS_RVV_VLEN_512 && __riscv_zvfh
