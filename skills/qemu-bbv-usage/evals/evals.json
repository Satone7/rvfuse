{
  "skill_name": "qemu-bbv-usage",
  "evals": [
    {
      "id": 1,
      "name": "basic-vector-program",
      "prompt": "我想用 QEMU 运行 output 目录下的一个 RISC-V 向量程序，程序是用 zvl256b 编译的，帮我构造命令。",
      "expected_output": "推荐使用 -cpu max,vlen=256 来匹配 VLEN=256，给出完整命令示例",
      "files": [],
      "assertions": [
        {
          "text": "Recommends -cpu max,vlen=256 for VLEN=256 match",
          "met": true,
          "evidence": "Model mentions vlen=256 flag"
        },
        {
          "text": "Includes -L sysroot flag",
          "met": true,
          "evidence": "Command has -L output/sysroot or similar"
        },
        {
          "text": "Uses qemu-riscv64 (user mode)",
          "met": true,
          "evidence": "Uses qemu-riscv64, not qemu-system"
        }
      ]
    },
    {
