        {
          "text": "Uses -plugin tools/bbv/libbbv.so",
          "met": true,
          "evidence": "Correct plugin path"
        },
        {
          "text": "Specifies interval=10000",
          "met": true,
          "evidence": "Interval parameter present"
        },
        {
          "text": "Specifies outfile=output/yolo.bbv",
          "met": true,
          "evidence": "Outfile parameter present"
        },
        {
          "text": "Includes -L output/sysroot",
          "met": true,
          "evidence": "Sysroot path specified"
        }
      ]
    },
