# RVFuse Project

# Git
.git/

# Third-party submodule build/install artifacts (if built locally)
third_party/*/build/
third_party/llvm-install/
third_party/*/*.o
third_party/*/*.a
third_party/*/*.so

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# Temporary files
*.tmp
*.log
.env*

# Build artifacts (future)
builds/
results/

# Python (future)
__pycache__/
*.pyc
.venv/
venv/
*.egg-info/
dist/

# Coverage (future)
coverage/

# Setup report (generated by setup.sh)
setup-report.txt

# Pre-cloned vendor sources for cross-compilation
applications/yolo/ort/vendor/
applications/llama.cpp/vendor/
applications/onnxrt/ort/vendor/

# Model files (large GGUF models)
applications/llama.cpp/models/*.gguf

# ONNX Runtime + YOLO build artifacts
output/*
!output/.gitkeep
!output/test_video.mp4
*.pt

# BBV plugin output files
bbv.out*.bb
bbv.out*.disas
tools/bbv/libbbv.so

# Demo test build artifacts (generated by verify_bbv.sh)
/demo.elf
/demo.c
test_bbv
tools/bbv/demo.elf

# Tools and Testing artifacts
tests/tools/*.o
tests/tools/*.elf
tests/tools/*.log
tests/tools/test_hello.c

# YOLO runner build directories
applications/yolo/runner/build-*/

# llvm-tblgen build artifacts (build/ dir handled by third_party/*/build/ pattern)
